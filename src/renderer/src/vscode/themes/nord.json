{
  "name": "Nord",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#88C0D0",
    "foreground": "#D8DEE9",
    "descriptionForeground": "#D8DEE999",
    "errorForeground": "#BF616A",
    "textLink.foreground": "#88C0D0",
    "selection.background": "#434C5E",

    "editor.background": "#2E3440",
    "editor.foreground": "#D8DEE9",
    "editorLineNumber.foreground": "#4C566A",
    "editorLineNumber.activeForeground": "#D8DEE9",
    "editorCursor.foreground": "#D8DEE9",
    "editor.selectionBackground": "#434C5E",
    "editor.inactiveSelectionBackground": "#3B4252",
    "editor.lineHighlightBackground": "#3B425266",
    "editor.wordHighlightBackground": "#4C566A66",
    "editor.wordHighlightStrongBackground": "#5E81AC66",
    "editor.findMatchBackground": "#EBCB8B66",
    "editor.findMatchHighlightBackground": "#EBCB8B33",
    "editorGutter.background": "#2E3440",
    "editorIndentGuide.background1": "#3B4252",
    "editorIndentGuide.activeBackground1": "#4C566A",
    "editorWhitespace.foreground": "#4C566A",

    "editorGroupHeader.tabsBackground": "#3B4252",
    "tab.activeBackground": "#2E3440",
    "tab.inactiveBackground": "#3B4252",
    "tab.activeForeground": "#ECEFF4",
    "tab.inactiveForeground": "#D8DEE999",
    "sideBar.background": "#3B4252",
    "sideBar.foreground": "#D8DEE9",
    "statusBar.background": "#5E81AC",
    "statusBar.foreground": "#ECEFF4",

    "peekView.border": "#5E81AC",
    "peekViewTitle.background": "#3B4252",
    "peekViewTitleLabel.foreground": "#ECEFF4",
    "peekViewTitleDescription.foreground": "#D8DEE999",
    "peekViewResult.background": "#2E3440",
    "peekViewResult.lineForeground": "#D8DEE9",
    "peekViewResult.fileForeground": "#ECEFF4",
    "peekViewResult.selectionBackground": "#434C5E",
    "peekViewResult.selectionForeground": "#ECEFF4",
    "peekViewResult.matchHighlightBackground": "#D0877066",
    "peekViewEditor.background": "#2E3440",
    "peekViewEditorGutter.background": "#2E3440",
    "peekViewEditorStickyScroll.background": "#2E3440",
    "peekViewEditorStickyScrollGutter.background": "#2E3440",
    "peekViewEditor.matchHighlightBackground": "#EBCB8B66",
    "peekViewEditor.matchHighlightBorder": "#EBCB8B"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#616E88", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#81A1C1" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#88C0D0" }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.struct",
        "entity.name.enum"
      ],
      "settings": { "foreground": "#8FBCBB" }
    },
    {
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#A3BE8C" }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "variable.other.constant"
      ],
      "settings": { "foreground": "#B48EAD" }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": { "foreground": "#D8DEE9" }
    },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#81A1C1" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#8FBCBB" } },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#ECEFF4", "background": "#BF616A" }
    },
    { "scope": ["markup.heading"], "settings": { "foreground": "#88C0D0", "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "fontStyle": "italic" } },
    { "scope": ["markup.bold"], "settings": { "fontStyle": "bold" } }
  ],
  "semanticTokenColors": {
    "namespace": "#8FBCBB",
    "type": "#8FBCBB",
    "class": "#8FBCBB",
    "enum": "#8FBCBB",
    "interface": "#8FBCBB",
    "struct": "#8FBCBB",
    "typeParameter": "#8FBCBB",
    "parameter": "#D8DEE9",
    "variable": "#D8DEE9",
    "property": "#D8DEE9",
    "enumMember": "#B48EAD",
    "function": "#88C0D0",
    "method": "#88C0D0",
    "macro": "#88C0D0",
    "keyword": "#81A1C1",
    "comment": { "foreground": "#616E88", "italic": true },
    "string": "#A3BE8C",
    "number": "#B48EAD",
    "regexp": "#EBCB8B",
    "operator": "#81A1C1"
  }
}
